# ============================================================================
# Another Me — environment configuration
# Copy to `.env` and fill in real values:   cp .env.example .env
# Every variable below has a working default for local/Compose dev EXCEPT the
# LLM API keys, which you must supply for real conversations.
# ============================================================================

# ---- LLM provider (switchable at runtime; R15 / SC3) -----------------------
# Which provider the orchestrator uses: "mock", "openai", or "anthropic".
# Default "mock" is deterministic and needs NO API key — the whole demo runs
# key-free. Switch to "openai"/"anthropic" and add the matching key below for
# real LLM calls. (If a real provider is selected but its key is missing, the
# backend logs a warning and auto-falls back to mock so the stack still boots.)
LLM_PROVIDER=mock
# Default model name (provider-specific; set to a model your key can access).
LLM_MODEL=gpt-5-mini
# Optional per-provider model overrides (used by the LLM layer if set).
OPENAI_MODEL=gpt-5-mini
ANTHROPIC_MODEL=claude-3-7-sonnet
# API keys — REQUIRED for real LLM calls (leave the unused one blank).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Optional base-URL overrides (e.g. Azure / proxy / self-hosted gateway).
OPENAI_BASE_URL=
ANTHROPIC_BASE_URL=
# Mock provider only: per-chunk SSE streaming delay in seconds. Keeps the live
# spectate view streaming turn-by-turn instead of resolving instantly. Real
# providers ignore this. Set 0 for instant (e.g. fast tests).
MOCK_STREAM_DELAY=0.04

# ---- Database --------------------------------------------------------------
# Used by Postgres container AND to build the default DATABASE_URL.
POSTGRES_USER=another_me
POSTGRES_PASSWORD=another_me
POSTGRES_DB=another_me
POSTGRES_PORT=5432
# Async SQLAlchemy URL.
#  - Docker Compose: host is the service name `db`.
#  - Local (no Compose): change `db` -> `localhost`.
DATABASE_URL=postgresql+asyncpg://another_me:another_me@db:5432/another_me

# ---- Auth ------------------------------------------------------------------
# CHANGE THIS in any non-throwaway environment.
JWT_SECRET=dev-insecure-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ---- Orchestration ---------------------------------------------------------
# Default per-agent max conversation rounds, and how many conversations may run
# concurrently.
MAX_ROUNDS=8
MAX_CONCURRENT_CONVERSATIONS=4

# ---- Sandbox ---------------------------------------------------------------
# Where the backend reaches the sandbox-runner.
#  - Docker Compose: http://sandbox-runner:8001
#  - Local (no Compose): http://localhost:8001
SANDBOX_URL=http://sandbox-runner:8001
SANDBOX_TIMEOUT_SECONDS=10

# ---- Frontend --------------------------------------------------------------
# Base URL the BROWSER uses to reach the backend. With Compose this is the
# host-published backend port (NOT the in-network http://backend:8000).
VITE_API_BASE_URL=http://localhost:8000

# ---- CORS (optional) -------------------------------------------------------
# Comma-separated allowed origins, or "*" for all (fine for hackathon/dev).
CORS_ORIGINS=*

# ---- Host port overrides (optional; Compose only) --------------------------
BACKEND_PORT=8000
FRONTEND_PORT=5173
