# ============================================================================
# Another Me — environment configuration
# Copy to `.env` and fill in real values:   cp .env.example .env
# Every variable below has a working default for local/Compose dev EXCEPT the
# LLM API keys, which you must supply for real conversations.
# ============================================================================

# ---- LLM provider (switchable at runtime) ---------------------------------
# Provider: "openai" (any OpenAI-compatible /chat/completions gateway, incl.
# GpuGeek and Aliyun DashScope), "anthropic", or "mock". The demo runs on the
# REAL model "DeepSeek-V4-Pro" via GpuGeek's OpenAI-compatible endpoint.
# If the selected real provider's key is missing OR a call fails (auth/network/
# rate-limit), the backend logs a warning and auto-falls back to the deterministic
# "mock" so the stack always runs.
LLM_PROVIDER=openai
# Default model name; keep in sync with the per-provider override below.
LLM_MODEL=DeepSeek-V4-Pro
# Per-provider model overrides (used by the LLM layer if set).
OPENAI_MODEL=DeepSeek-V4-Pro
ANTHROPIC_MODEL=claude-3-7-sonnet
# API keys — REQUIRED for real LLM calls (leave blank to run on the mock fallback).
# For the demo, put your GpuGeek key here (the shipped .env already has a working one).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Base-URL override (OpenAI-compatible gateway). The demo uses GpuGeek:
#   GpuGeek:   https://api.gpugeek.com/v1   (model: DeepSeek-V4-Pro)
#   DashScope: https://dashscope.aliyuncs.com/compatible-mode/v1
#   hosted OpenAI: leave empty to use api.openai.com
OPENAI_BASE_URL=https://api.gpugeek.com/v1
ANTHROPIC_BASE_URL=
# Mock provider only: per-chunk SSE streaming delay in seconds. Keeps the live
# spectate view streaming turn-by-turn instead of resolving instantly. Real
# providers ignore this. Set 0 for instant (e.g. fast tests).
MOCK_STREAM_DELAY=0.04

# ---- Database --------------------------------------------------------------
# Used by Postgres container AND to build the default DATABASE_URL.
POSTGRES_USER=another_me
POSTGRES_PASSWORD=another_me
POSTGRES_DB=another_me
POSTGRES_PORT=5432
# Async SQLAlchemy URL.
#  - Docker Compose: host is the service name `db`.
#  - Local (no Compose): change `db` -> `localhost`.
DATABASE_URL=postgresql+asyncpg://another_me:another_me@db:5432/another_me

# ---- Auth ------------------------------------------------------------------
# CHANGE THIS in any non-throwaway environment.
JWT_SECRET=dev-insecure-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ---- Orchestration ---------------------------------------------------------
# Default per-agent max conversation rounds, and how many conversations may run
# concurrently.
MAX_ROUNDS=8
MAX_CONCURRENT_CONVERSATIONS=4

# ---- Trips (autonomous "travelling-frog" journeys, §6) ---------------------
# Default wall-clock duration (seconds) a dispatched trip is spread over: the twin
# travels through 2–4 encounters interleaved with travel pauses summing to ~this.
# This is the canonical knob and applies when a trip request omits duration_seconds.
#   demo  → keep it small (e.g. 45) so a journey finishes in under a minute
#   prod  → raise it (minutes/hours) for a slower, more "alive" travelling-frog world
TRIP_DURATION_SECONDS=45
# Deprecated v1 alias of TRIP_DURATION_SECONDS; left for back-compat (unused by
# new code). Safe to remove once nothing reads settings.trip_duration.
TRIP_DURATION=60

# ---- Sandbox ---------------------------------------------------------------
# Where the backend reaches the sandbox-runner.
#  - Docker Compose: http://sandbox-runner:8001
#  - Local (no Compose): http://localhost:8001
SANDBOX_URL=http://sandbox-runner:8001
SANDBOX_TIMEOUT_SECONDS=10

# ---- Frontend --------------------------------------------------------------
# Base URL the BROWSER uses to reach the backend.
#   - Behind the `gateway` (self-hosted server / EdgeOne): leave EMPTY so the
#     app calls the API same-origin at /api (no CORS, no mixed-content).
#   - Standalone local dev without the gateway: set http://localhost:8000.
VITE_API_BASE_URL=

# ---- CORS (optional) -------------------------------------------------------
# Comma-separated allowed origins, or "*" for all (fine for hackathon/dev).
CORS_ORIGINS=*

# ---- Host port overrides (optional; Compose only) --------------------------
BACKEND_PORT=8000
FRONTEND_PORT=5173
# Public port the `gateway` listens on; EdgeOne does HTTP origin-pull here.
GATEWAY_PORT=80
